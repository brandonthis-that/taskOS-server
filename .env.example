# Listen address (use :8080 behind reverse proxy on Ubuntu)
TASKOS_ADDR=:8080

# PostgreSQL connection URL
# Format: postgres://user:password@host:5432/dbname?sslmode=disable
TASKOS_DATABASE_URL=postgres://taskos:secret@localhost:5432/taskos?sslmode=disable

# Comma-separated CORS origins (* for development only)
TASKOS_CORS_ORIGINS=https://myapp.example.com

# Requests per minute per client IP
TASKOS_RATE_LIMIT_PER_MIN=120

# Graceful shutdown timeout
TASKOS_SHUTDOWN_TIMEOUT=10s
