# Copy this file to .env and edit the values.
# The .env file is gitignored.

# Postgres credentials. On first `docker compose up`, Postgres initializes
# its data volume with these values. Changing them later has no effect
# unless the volume is recreated (`docker compose down -v`).
DB_USER=taskos
DB_PASSWORD=change-me
DB_NAME=taskos_db

# Where the Go server reaches Postgres.
# Use `localhost` when running the server on the host.
# Use `postgres_db` (the compose service name) when running the server
# inside the same compose network.
DB_HOST=localhost
DB_PORT=5432

# HTTP listen address for the API server.
HTTP_ADDR=:8080

# How long a session token is valid for, in hours. Default: 30 days.
SESSION_HOURS=720
